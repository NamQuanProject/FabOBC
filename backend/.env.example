# --- Supabase ---
# FabOPC has no self-hosted database and the backend never opens a direct
# Postgres connection — every read/write goes through Supabase's REST API
# via the async client in database/client.py. Project Settings -> API.
SUPABASE_URL=https://<project-ref>.supabase.co
# Use the service_role secret here (not the anon/publishable key): the
# backend is a trusted server context and needs to read/write freely
# regardless of any Row Level Security policies. Never ship this key to
# the frontend.
SUPABASE_KEY=<service-role-secret-key>

# Create/reset tables and sample data directly in the Supabase SQL Editor:
#   sql/init_postgresql.sql    (schema)
#   sql/seed_sample_data.sql   (sample company/users/KPIs/tasks for UI testing)

# --- Gemini / Google ADK ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- FastAPI gateway ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Agent host/ports (one A2A server process per agent) ---
AGENT_HOST=127.0.0.1
ORCHESTRATOR_AGENT_PORT=9990
FINANCE_AGENT_PORT=9991
MARKETING_AGENT_PORT=9992
OPERATIONS_AGENT_PORT=9993
HR_AGENT_PORT=9994
COMPLIANCE_AGENT_PORT=9995
BI_AGENT_PORT=9996
