# --- Supabase Postgres ---
# FabOPC has no self-hosted database — Supabase's own Postgres instance IS
# the database. DATABASE_URL is the direct SQLAlchemy/asyncpg connection to
# it (used for all relational data: users, OPC profiles, KPIs, tasks, chat).
# Get the pieces from Supabase Dashboard -> Project Settings -> Database:
#   - Direct connection:  db.<project-ref>.supabase.co:5432
#   - Session pooler (use this if your network is IPv4-only / direct times out):
#       aws-0-<region>.pooler.supabase.com:5432, user "postgres.<project-ref>"
DATABASE_URL=postgresql+asyncpg://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# SUPABASE_URL / SUPABASE_KEY are for the Supabase SDK client
# (database/client.py) — storage buckets, auth admin, realtime. Project
# Settings -> API. The publishable/anon key is fine here.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-or-publishable-key>

# --- Gemini / Google ADK ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- FastAPI gateway ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Agent host/ports (one A2A server process per agent) ---
AGENT_HOST=127.0.0.1
ORCHESTRATOR_AGENT_PORT=9990
FINANCE_AGENT_PORT=9991
MARKETING_AGENT_PORT=9992
OPERATIONS_AGENT_PORT=9993
HR_AGENT_PORT=9994
COMPLIANCE_AGENT_PORT=9995
BI_AGENT_PORT=9996
